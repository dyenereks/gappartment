# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx

# Clerk redirect URLs (leave as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/setup-profile

# Clerk Webhook Secret (for production)
# Create a webhook at https://dashboard.clerk.com pointing to /api/webhooks/clerk
# Subscribe to: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET=whsec_xxxx

# Convex — set by `npx convex dev` (writes to .env.local automatically)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# UploadThing v7 (for QR codes & payment proofs)
# Get your token from https://uploadthing.com → App → API Keys → Token
# The token is a base64 string that combines your API key and app ID
UPLOADTHING_TOKEN=eyxxxx

# Web Push (notifications) — generate with: npx web-push generate-vapid-keys
# Only the PUBLIC key goes here; PRIVATE key + SUBJECT live on Convex env.
#   npx convex env set VAPID_PUBLIC_KEY  ...
#   npx convex env set VAPID_PRIVATE_KEY ...
#   npx convex env set VAPID_SUBJECT     mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Leyeco2 electric bill sync
# GET /api/leyeco/sync — fetches your bill and saves it to the app
LEYECO_ACCOUNT_NUMBER=01-1117-6203
# Optional: protect the sync endpoint with a bearer token
# curl -H "Authorization: Bearer <secret>" https://your-app.com/api/leyeco/sync
LEYECO_SYNC_SECRET=
