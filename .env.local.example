# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx

# Clerk redirect URLs (leave as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Clerk Webhook Secret (for production)
# Create a webhook at https://dashboard.clerk.com pointing to /api/webhooks/clerk
# Subscribe to: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET=whsec_xxxx

# Database (SQLite - no change needed for local dev)
DATABASE_URL="file:./prisma/dev.db"

# UploadThing v7 (for QR codes & payment proofs)
# Get your token from https://uploadthing.com → App → API Keys → Token
# The token is a base64 string that combines your API key and app ID
UPLOADTHING_TOKEN=eyxxxx
